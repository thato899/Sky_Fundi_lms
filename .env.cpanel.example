# Sky Fundi native cPanel production contract.
# Copy to /home/CPANEL_USER/sky-fundi-shared/.env and replace placeholders.
# Never commit the resulting .env or any real credentials.

APP_NAME="CHANGE_ME_APPLICATION_NAME"
APP_ENV=production
APP_KEY=CHANGE_ME_GENERATE_WITH_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://CHANGE_ME_APPLICATION_DOMAIN
APP_TIMEZONE=Africa/Johannesburg
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=CHANGE_ME_CPANEL_DATABASE_HOST
DB_PORT=3306
DB_DATABASE=CHANGE_ME_CPANEL_DATABASE_NAME
DB_USERNAME=CHANGE_ME_CPANEL_DATABASE_USERNAME
DB_PASSWORD=CHANGE_ME_RANDOM_DATABASE_PASSWORD

CACHE_STORE=database
CACHE_PREFIX=sky_fundi_cache_
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM_ADDRESS=CHANGE_ME_VERIFIED_FROM_ADDRESS
MAIL_FROM_NAME="CHANGE_ME_APPLICATION_NAME"

AI_DEFAULT_PROVIDER=deepseek
AI_FALLBACK_PROVIDER=
AI_MAX_RETRIES=1
AI_OLLAMA_ENABLED=false
AI_DEEPSEEK_ENABLED=false
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_API_KEY=CHANGE_ME_ONLY_WHEN_DEEPSEEK_IS_ENABLED
AI_DEEPSEEK_MODEL=deepseek-chat
AI_OPENAI_ENABLED=false
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=CHANGE_ME_ONLY_WHEN_OPENAI_IS_ENABLED
AI_OPENAI_MODEL=gpt-5-mini
AI_CLAUDE_ENABLED=false
AI_GEMINI_ENABLED=false

# Configure only when the account is behind a trusted cPanel proxy.
TRUSTED_PROXIES=
SANCTUM_STATEFUL_DOMAINS=CHANGE_ME_APPLICATION_DOMAIN

BACKUP_DESTINATION=/home/CPANEL_USER/sky-fundi-shared/backups
