# Sky Fundi production contract. Copy to .env.production, restrict it to the
# deployment user, and replace every CHANGE_ME value. Never commit that file.

# Required application identity and security
APP_NAME="Sky Fundi Platform"
APP_ENV=production
APP_KEY=CHANGE_ME_GENERATE_WITH_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://staging.example.invalid
APP_DOMAIN=staging.example.invalid
ACME_EMAIL=CHANGE_ME_OPERATIONS_EMAIL
APP_TIMEZONE=Africa/Johannesburg
APP_LOCALE=en
APP_IMAGE=sky-fundi-app
WEB_IMAGE=sky-fundi-web
APP_IMAGE_TAG=CHANGE_ME_IMMUTABLE_RELEASE

# Public bindings. Permit only 22/tcp, 80/tcp, and 443/tcp+udp at the firewall.
HTTP_BIND_ADDRESS=0.0.0.0
HTTP_PORT=80
HTTPS_BIND_ADDRESS=0.0.0.0
HTTPS_PORT=443
CADDY_MAX_UPLOAD_SIZE=25MB
CADDY_APP_READ_TIMEOUT=60s
CADDY_APP_WRITE_TIMEOUT=60s

# Required database values. MYSQL_ROOT_PASSWORD_FILE is a host file containing
# only a generated root password; chmod 600 it. DB_PASSWORD is never committed.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skyfundi
DB_USERNAME=skyfundi
DB_PASSWORD=CHANGE_ME_RANDOM_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD_FILE=./secrets/mysql_root_password

# Database-backed state avoids adding Redis to this single-server milestone.
CACHE_STORE=database
CACHE_PREFIX=sky_fundi_cache_
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120

# Durable local storage. The named storage volume holds private and public
# uploads; FILESYSTEM_DISK=local remains private by default.
FILESYSTEM_DISK=local
BACKUP_DESTINATION=/var/www/html/storage/app/backups

# Production mail provider. Do not use Mailpit here.
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM_ADDRESS=CHANGE_ME_VERIFIED_FROM_ADDRESS
MAIL_FROM_NAME="Sky Fundi Platform"
MAIL_DEFAULT_PROVIDER=smtp

# Bounded application and container logging
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

# Request correlation and slow-operation thresholds
OBSERVABILITY_REQUEST_ID_HEADER=X-Request-ID
OBSERVABILITY_SLOW_REQUEST_MS=1000
OBSERVABILITY_SLOW_QUERY_MS=500

# Authentication and API cookies
SANCTUM_STATEFUL_DOMAINS=staging.example.invalid
SANCTUM_TOKEN_EXPIRATION=43200
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_PASSWORD_EXPIRY_DAYS=90

# Initial administration values are used only for an explicitly approved,
# one-time seed. Deployment never seeds and these should remain unset normally.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# External AI is disabled for staging until an operator deliberately configures
# a supported provider. No provider credentials are required for readiness.
AI_DEFAULT_PROVIDER=ollama
AI_FALLBACK_PROVIDER=
AI_MAX_RETRIES=1
AI_OLLAMA_ENABLED=false
AI_DEEPSEEK_ENABLED=false
AI_OPENAI_ENABLED=false
AI_CLAUDE_ENABLED=false
AI_GEMINI_ENABLED=false
