# Sky Fundi Platform — Environment Variables
# Copy this file to .env and fill in real values for your environment.
# See docs/environment-variables.md for the full guide.
# NEVER commit a real .env file or real secret values.

# --- Application ---
APP_NAME="Sky Fundi Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en
LOG_CHANNEL=stack
LOG_LEVEL=debug
OBSERVABILITY_REQUEST_ID_HEADER=X-Request-ID
OBSERVABILITY_SLOW_REQUEST_MS=1000
OBSERVABILITY_SLOW_QUERY_MS=500

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

# --- Sanctum (API tokens) ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION=43200

# --- Account Security (core/Auth, core/Users) — see docs/security/policies.md ---
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_PASSWORD_EXPIRY_DAYS=90

# --- Initial Super Admin (database/seeders/SuperAdminUserSeeder.php) ---
# Set before running `php artisan db:seed` on a fresh install. Leave
# unset thereafter — do not keep production credentials in .env.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skyfundi
DB_USERNAME=skyfundi
DB_PASSWORD=skyfundi

# --- Redis / Cache / Queue ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Mail (core/Notifications, core/Mail) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@localhost.test
MAIL_DEFAULT_PROVIDER=smtp
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# --- AI Gateway (core/AIGateway) — see docs/ai/ai-gateway.md ---
AI_DEFAULT_PROVIDER=ollama
AI_FALLBACK_PROVIDER=
AI_MAX_RETRIES=1

AI_OLLAMA_ENABLED=true
AI_OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_OLLAMA_MODEL=qwen3:8b
AI_OLLAMA_TIMEOUT=60

AI_DEEPSEEK_ENABLED=false
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat
AI_DEEPSEEK_TIMEOUT=60

# Placeholder providers — see core/AIGateway/Infrastructure/Providers.
# Setting a key does not enable these; adapters are not implemented yet.
AI_OPENAI_ENABLED=false
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_MODEL=gpt-5-mini
AI_OPENAI_TIMEOUT=20
AI_OPENAI_MAX_RETRIES=1
AI_MARKING_ENABLED=true
AI_MARKING_MAX_OUTPUT_TOKENS=900
AI_MONTHLY_MARKING_ALLOWANCE=250
# Demo estimates only; configure for the selected model and currency assumptions.
AI_INPUT_COST_PER_MILLION=4.50
AI_OUTPUT_COST_PER_MILLION=18.00
AI_CLAUDE_ENABLED=false
AI_CLAUDE_API_KEY=
AI_CLAUDE_MODEL=claude-sonnet-4-6
AI_GEMINI_ENABLED=false
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash

# --- Storage (core/Storage) ---
FILESYSTEM_DISK=local

# --- Billing (core/Billing) ---
BILLING_PROVIDER=
HACKATHON_DEMO_PASSWORD=
DEMO_MODE=false
DEMO_NOTIFICATION_COST=35
DEMO_HOSTING_ALLOCATION=180
DEMO_SUPPORT_ALLOCATION=250

# --- Backups (core/Backup) ---
BACKUP_DESTINATION=

# --- Multi-Tenancy ---
DEFAULT_TENANT_ISOLATION=database-per-tenant
