# Sky Fundi Platform — Environment Variables
# Copy this file to .env and fill in real values for your environment.
# See docs/environment-variables.md for the full guide.
# NEVER commit a real .env file or real secret values.

# --- Application ---
APP_NAME="Sky Fundi Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sky_fundi
DB_USERNAME=
DB_PASSWORD=

# --- Redis / Cache / Queue ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Mail (core/Notifications) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=

# --- AI Gateway (core/AIGateway) — see docs/ai/ai-gateway.md ---
AI_DEFAULT_PROVIDER=ollama
AI_OLLAMA_BASE_URL=http://localhost:11434
AI_OPENAI_API_KEY=
AI_CLAUDE_API_KEY=
AI_GEMINI_API_KEY=
AI_DEEPSEEK_API_KEY=

# --- Storage (core/Storage) ---
FILESYSTEM_DISK=local

# --- Billing (core/Billing) ---
BILLING_PROVIDER=

# --- Multi-Tenancy ---
DEFAULT_TENANT_ISOLATION=database-per-tenant
